# ─────────────────────────────────────────────────────────────────────────────
# AutoOps AI — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────

# OPTIONAL — Anthropic API Key
# If set:   PlannerAgent + ReviewerAgent use the real Claude API (recommended for production)
# If empty: Both agents fall back to rule-based mock mode (great for local dev / CI)
ANTHROPIC_API_KEY=

# Model to use (only applies when ANTHROPIC_API_KEY is set)
CLAUDE_MODEL=claude-sonnet-4-20250514

# App settings
APP_NAME=AutoOps AI
DEBUG=True

# Vector / Memory store
CHROMA_PERSIST_DIR=./chroma_db
EMBEDDING_MODEL=all-MiniLM-L6-v2
