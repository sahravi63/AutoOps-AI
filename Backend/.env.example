# AutoOps AI — Environment Variables
# ====================================
# ALL API keys are optional. Provide any ONE to enable real LLM mode.
# Priority: Anthropic → Groq → HuggingFace → mock (rule-based)

# --- Anthropic (claude-haiku is cheapest; free trial credits available) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Groq (generous free tier: https://console.groq.com) ---
# GROQ_API_KEY=gsk_...

# --- HuggingFace Inference API (free tier: https://huggingface.co/settings/tokens) ---
# HF_API_KEY=hf_...

# --- Optional: override the default model for each provider ---
# CLAUDE_MODEL=claude-haiku-4-5-20251001
# GROQ_MODEL=llama-3.3-70b-versatile
# HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# --- App settings ---
APP_NAME=AutoOps AI
DEBUG=True
